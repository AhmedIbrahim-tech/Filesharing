<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper mb-5">
    <div class="container text-center pt-5">
        <h1 class="hero-title animate__animated animate__fadeInDown">@Localizer["About Us"]</h1>
        <p class="text-muted animate__animated animate__fadeInUp">@Localizer["Empowering the community through seamless file sharing."]</p>
    </div>
</div>

<main class="container pb-5">
    <!-- Who we are -->
    <section class="py-5 mt-5">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="mu-title text-start mb-4">
                    <h2 class="display-4 font-weight-bold mb-4">@Localizer["Who"] <span class="text-gradient">@Localizer["We Are"]</span></h2>
                    <p class="text-muted lead mb-4">
                        @Localizer["We are a community-driven platform dedicated to making file sharing fast, secure, and accessible to everyone. Our platform is built on transparency and the collective power of knowledge sharing."]
                    </p>
                </div>
                <div class="row g-4 mt-2">
                    <div class="col-sm-6">
                        <div class="download-card p-4 animate__animated animate__zoomIn">
                            <div class="card-icon mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                <i class="bi bi-shield-check"></i>
                            </div>
                            <h4 class="h5">@Localizer["Secure"]</h4>
                            <p class="text-muted small mb-0">@Localizer["Your files are handled with the highest security standards."]</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="download-card p-4 animate__animated animate__zoomIn" style="animation-delay: 0.2s;">
                            <div class="card-icon mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                <i class="bi bi-lightning-charge"></i>
                            </div>
                            <h4 class="h5">@Localizer["Fast"]</h4>
                            <p class="text-muted small mb-0">@Localizer["High-speed uploads and downloads without limits."]</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="rounded-4 overflow-hidden shadow-2xl animate__animated animate__fadeInRight" style="border: 1px solid var(--border); box-shadow: 0 25px 50px -12px rgba(56, 189, 248, 0.25);">
                    <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&q=80&w=1000" class="img-fluid" alt="Our Team">
                </div>
            </div>
        </div>
    </section>

    <!-- Mission & Vision -->
    <section class="py-5 mt-5">
        <div class="row g-4">
            <div class="col-lg-4">
                <div class="download-card h-100 p-4 text-center glass-hover transition-all">
                    <div class="card-icon mx-auto mb-4" style="width: 70px; height: 70px; font-size: 2.5rem;">
                        <i class="bi bi-bullseye"></i>
                    </div>
                    <h3 class="h4 mb-3">@Localizer["Our Mission"]</h3>
                    <p class="text-muted">@Localizer["To bridge the gap between people through open and secure exchange of information and digital assets."]</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="download-card h-100 p-4 text-center glass-hover transition-all">
                    <div class="card-icon mx-auto mb-4" style="width: 70px; height: 70px; font-size: 2.5rem;">
                        <i class="bi bi-eye"></i>
                    </div>
                    <h3 class="h4 mb-3">@Localizer["Our Vision"]</h3>
                    <p class="text-muted">@Localizer["To build a global library where every student and professional can find the resources they need instantly."]</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="download-card h-100 p-4 text-center glass-hover transition-all">
                    <div class="card-icon mx-auto mb-4" style="width: 70px; height: 70px; font-size: 2.5rem;">
                        <i class="bi bi-heart"></i>
                    </div>
                    <h3 class="h4 mb-3">@Localizer["Our Values"]</h3>
                    <p class="text-muted">@Localizer["Integrity, community growth, and unrestricted access to public knowledge are the pillars of our platform."]</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="my-5 py-5 rounded-4 glass p-5 text-center animate__animated animate__fadeInUp" style="border: 1px solid var(--border);">
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <h2 class="text-gradient display-4 font-weight-bold mb-0">10M+</h2>
                <p class="text-muted mb-0 font-weight-600">@Localizer["Files Shared"]</p>
            </div>
            <div class="col-sm-6 col-lg-3">
                <h2 class="text-gradient display-4 font-weight-bold mb-0">500K+</h2>
                <p class="text-muted mb-0 font-weight-600">@Localizer["Active Users"]</p>
            </div>
            <div class="col-sm-6 col-lg-3">
                <h2 class="text-gradient display-4 font-weight-bold mb-0">2.5PB</h2>
                <p class="text-muted mb-0 font-weight-600">@Localizer["Data Transferred"]</p>
            </div>
            <div class="col-sm-6 col-lg-3">
                <h2 class="text-gradient display-4 font-weight-bold mb-0">24/7</h2>
                <p class="text-muted mb-0 font-weight-600">@Localizer["Support"]</p>
            </div>
        </div>
    </section>
</main>
			
		

