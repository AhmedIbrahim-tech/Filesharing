@model ChangePasswordViewModel

<form id="change-password" class="mu-contact-form" asp-controller="Account" asp-action="ChangePassword" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
    
    <div class="row g-4 text-start">
        <div class="col-md-12 mb-4">
            <label class="text-muted small mb-2 ml-2">@Localizer["Current Password"]</label>
            <div class="position-relative">
                <i class="bi bi-shield-lock position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                <input type="password" asp-for="CurrentPassword" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 1.25rem 1.25rem 3.5rem;" placeholder="Old Password" required>
            </div>
            <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 ml-2"></span>
        </div>

        <div class="col-md-12 mb-4">
            <label class="text-muted small mb-2 ml-2">@Localizer["New Password"]</label>
            <div class="position-relative">
                <i class="bi bi-key position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                <input type="password" asp-for="NewPassword" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 1.25rem 1.25rem 3.5rem;" placeholder="New Security Key" required>
            </div>
            <span asp-validation-for="NewPassword" class="text-danger small mt-1 ml-2"></span>
        </div>

        <div class="col-md-12 mb-5">
            <label class="text-muted small mb-2 ml-2">@Localizer["Confirm Password"]</label>
            <div class="position-relative">
                <i class="bi bi-check2-circle position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                <input type="password" asp-for="ConfirmPassword" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 1.25rem 1.25rem 3.5rem;" placeholder="Confirm Security Key" required>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 ml-2"></span>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary-modern btn-modern w-100 justify-content-center rounded-pill py-3">
                <i class="bi bi-save mr-2"></i> @Localizer["Update Password"]
            </button>
        </div>
    </div>
</form>