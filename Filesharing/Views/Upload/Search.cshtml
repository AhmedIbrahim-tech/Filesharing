@model IEnumerable<UploadViewModel>
@{
    var ContentTypeArr = new[] { "image/png", "image/jpeg" };
}

<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper pb-5 pt-5">
    <div class="container text-center">
        <h1 class="hero-title pt-5">@Localizer["Search Results"]</h1>
        <p class="text-muted">Showing results for your query.</p>
    </div>
</div>

<div class="container mt-5 pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5 animate__animated animate__fadeIn">
            <div class="card-icon mx-auto mb-4" style="width: 100px; height: 100px; font-size: 4rem; opacity: 0.5;">
                <i class="bi bi-search"></i>
            </div>
            <h3 class="text-muted">No files found matching your search.</h3>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary-modern btn-modern mt-3 rounded-pill px-4">
                Try Another Search
            </a>
        </div>
    }
    else
    {
        <div class="download-grid">
            @foreach (var item in Model)
            {
                <div class="download-card animate__animated animate__fadeInUp">
                    @if (ContentTypeArr.Contains(item.ContentType))
                    {
                        <img src="~/Uploads/@item.FileName" class="card-thumbnail" alt="@item.OriginalFileName" />
                    }
                    else
                    {
                        var fileExt = System.IO.Path.GetExtension(item.OriginalFileName).ToLower();
                        var iconClass = fileExt switch {
                            ".pdf" => "bi-file-pdf pdf",
                            ".zip" or ".rar" => "bi-file-zip zip",
                            ".doc" or ".docx" => "bi-file-word doc",
                            ".xls" or ".xlsx" => "bi-file-excel xls",
                            ".txt" => "bi-file-text txt",
                            _ => "bi-file-earmark"
                        };
                        
                        <div class="card-icon @iconClass.Split(' ').Last()">
                            <i class="bi @iconClass.Split(' ').First()"></i>
                        </div>
                    }

                    <div class="card-info">
                        <h3 class="mb-2 text-truncate" title="@item.OriginalFileName">@item.OriginalFileName</h3>
                        <div class="d-flex align-items-center gap-3 card-meta mb-3">
                            <span><i class="bi bi-cloud-download me-1"></i> @item.DownloadCount</span>
                            <span><i class="bi bi-hdd me-1"></i> @((item.Size / 1024).ToString("F2")) KB</span>
                            <span><i class="bi bi-calendar3 me-1"></i> @item.UploadDate.ToShortDateString()</span>
                        </div>
                    </div>

                    <div class="mt-auto pt-3 border-top border-secondary d-flex justify-content-between align-items-center" style="border-top-color: var(--border) !important;">
                        <span class="text-muted small">@Localizer["shared by"] <span class="text-primary font-weight-bold">@Localizer["Community"]</span></span>
                        <a asp-controller="Upload" asp-action="Download" asp-route-id="@item.FileName" class="btn btn-primary-modern btn-modern btn-sm rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);">
                            <i class="bi bi-download" style="font-size: 1.1rem;"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
