@model IEnumerable<UploadViewModel>
@{
    ViewData["Title"] = "Index";
    Layout = "_Layout";

    var ContentTypeArr = new[] { "image/png", "image/jpeg", "image/jpg", "image/gif" };
}


<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper mb-5">
    <div class="container text-center">
        <h1 class="hero-title pt-5">@Localizer["My Uploads"]</h1>
        <p class="text-muted">Manage your shared files and track their performance.</p>
        
        <div class="mt-4">
             <a class="btn btn-primary-modern btn-modern rounded-pill" asp-action="Create">
                <i class="bi bi-plus-circle mr-2"></i> @Localizer["Upload New File"]
            </a>
        </div>
    </div>
</div>

<div class="container mt-5 pb-5">
    <div class="row">
        <div class="col-12">
            <div class="download-grid">
                @foreach (var item in Model)
                {
                    <div class="download-card animate__animated animate__fadeInUp">
                        @if (ContentTypeArr.Contains(item.ContentType))
                        {
                            <img src="~/Uploads/@item.FileName" class="card-thumbnail" alt="@item.OriginalFileName" />
                        }
                        else
                        {
                            var fileExt = System.IO.Path.GetExtension(item.OriginalFileName).ToLower();
                            var iconClass = fileExt switch {
                                ".pdf" => "bi-file-pdf pdf",
                                ".zip" or ".rar" => "bi-file-zip zip",
                                ".doc" or ".docx" => "bi-file-word doc",
                                ".xls" or ".xlsx" => "bi-file-excel xls",
                                ".txt" => "bi-file-text txt",
                                _ => "bi-file-earmark"
                            };
                            
                            <div class="card-icon @iconClass.Split(' ').Last()">
                                <i class="bi @iconClass.Split(' ').First()"></i>
                            </div>
                        }

                        <div class="card-info">
                            <h3 class="mb-2 text-truncate" title="@item.OriginalFileName">@item.OriginalFileName</h3>
                            <div class="card-meta d-flex flex-wrap gap-3">
                                <span><i class="bi bi-hdd mr-1"></i> 
                                    @{
                                        var size = item.Size / 1024;
                                        if (size < 1024) { @(Math.Floor(Convert.ToDecimal(size))) @:Kb 
                                        } else { @(Math.Round(Convert.ToDecimal(size) / 1024, 2)) @:Mb 
                                        }
                                    }
                                </span>
                                <span><i class="bi bi-download mr-1"></i> @item.DownloadCount</span>
                            </div>
                        </div>

                        <div class="mt-auto pt-4 d-flex align-items-center justify-content-between border-top border-white-10" style="border-top-color: rgba(255,255,255,0.05) !important;">
                             <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-outline-danger rounded-pill px-3 py-2 d-flex align-items-center transition-all">
                                <i class="bi bi-trash-fill me-2"></i> @Localizer["Delete"]
                             </a>
                             <a asp-controller="Upload" asp-action="Download" asp-route-id="@item.FileName" class="btn btn-sm btn-primary-modern rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; min-width: 38px;">
                                <i class="bi bi-download"></i>
                             </a>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="text-center py-5 glass rounded-4 border-dashed" style="border: 2px dashed var(--border);">
                    <i class="bi bi-cloud-upload display-1 text-muted mb-4"></i>
                    <h3 class="text-muted">You haven't uploaded any files yet.</h3>
                    <a asp-action="Create" class="btn btn-primary-modern btn-modern mt-3 rounded-pill">Upload your first file</a>
                </div>
            }
        </div>
    </div>
</div>

