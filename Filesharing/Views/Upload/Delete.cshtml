@model UploadViewModel

<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper pb-5 pt-5">
    <div class="container text-center">
        <h1 class="hero-title pt-5">@Localizer["Confirm Deletion"]</h1>
        <p class="text-danger">This action cannot be undone.</p>
    </div>
</div>

<div class="container mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 animate__animated animate__shakeX">
            <div class="download-card p-5 text-center" style="border-top: 4px solid #ef4444;">
                <div class="card-icon mx-auto mb-4 bg-danger-soft text-danger" style="width: 80px; height: 80px; font-size: 3rem; background: rgba(239, 68, 68, 0.1); border-radius: 50%; line-height: 80px;">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                
                <h3 class="font-weight-bold mb-4 text-white">@Localizer["Are you sure?"]</h3>
                
                <div class="mb-5 p-4 rounded-4" style="background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border);">
                    <div class="mb-3">
                        @if (Model.ContentType.Contains("image"))
                        {
                            <img src="/Uploads/@Model.FileName" class="rounded-4 shadow-lg mb-3" style="max-width: 150px; border: 1px solid var(--border);" />
                        }
                        else
                        {
                            <div class="card-icon mx-auto mb-3" style="width: 60px; height: 60px; font-size: 2rem;">
                                <i class="bi bi-file-earmark"></i>
                            </div>
                        }
                    </div>
                    <h5 class="text-white mb-1">@Model.OriginalFileName</h5>
                    <p class="text-muted small mb-0">@((Model.Size / 1024).ToString("F2")) KB • @Model.UploadDate.ToShortDateString()</p>
                </div>

                <form asp-action="Delete">
                    <input type="hidden" asp-for="ID" />
                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-outline-modern btn-modern w-50 justify-content-center rounded-pill py-3">
                            <i class="bi bi-x-circle mr-2"></i> @Localizer["Cancel"]
                        </a>
                        <button type="submit" class="btn btn-danger w-50 justify-content-center rounded-pill py-3" style="background: #ef4444; border: none; font-weight: 600;">
                            <i class="bi bi-trash mr-2"></i> @Localizer["Delete File"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
