@inject IViewLocalizer Localizer;

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower();
}

<header id="mu-hero" class="bg-glass sticky-top" style="backdrop-filter: blur(20px); border-bottom: 1px solid var(--border);">
    <div class="container">
        <nav class="navbar navbar-expand-lg navbar-dark p-0" style="height: 80px;">
            <!-- Logo -->
            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                 <div class="logo-icon bg-primary-soft me-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; border-radius: 12px; background: rgba(56, 189, 248, 0.15);">
                    <i class="bi bi-cloud-arrow-up text-primary" style="font-size: 1.3rem;"></i>
                 </div>
                 <span class="mu-logo text-white fw-bold" style="font-size: 1.4rem; letter-spacing: -0.5px;">File<span class="text-primary">Sharing</span></span>
             </a>

            <button class="navbar-toggler border-0 shadow-none ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list h2 mb-0 text-white"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav ms-lg-5 me-auto mb-2 mb-lg-0 gap-lg-4 gap-2">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "home" && currentAction == "index" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-2"></i>@Localizer["Home"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "upload" && currentAction == "browse" ? "active" : "")" asp-area="" asp-controller="Upload" asp-action="Browse">
                            <i class="bi bi-compass me-2"></i>@Localizer["Browse"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "home" && currentAction == "about" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="About">
                            <i class="bi bi-info-circle me-2"></i>@Localizer["About"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "home" && currentAction == "contact" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope me-2"></i>@Localizer["Contact"]
                        </a>
                    </li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "upload" && currentAction == "index" ? "active" : "")" asp-area="" asp-controller="Upload" asp-action="Index">
                                <i class="bi bi-cloud-arrow-up me-2"></i>@Localizer["Uploads"]
                            </a>
                        </li>
                    }

                    <li class="nav-item d-flex align-items-center ms-lg-4">
                        @{
                            var culture = Context.Features.Get<Microsoft.AspNetCore.Localization.IRequestCultureFeature>()?.RequestCulture.Culture.Name;
                            if (culture == "ar-SA")
                            {
                                <a class="nav-link animate__animated animate__fadeIn p-0" href="/Home/SetLang?Lang=en-US&returnUrl=@Context.Request.Path" title="Switch to English">
                                    <span class="badge bg-glass text-white rounded-pill px-3 py-2 border border-white-10 d-flex align-items-center hover-glow" style="background: rgba(255,255,255,0.05);">
                                       <span class="fi fi-gb me-2 rounded-1"></span> English
                                    </span>
                                </a>
                            }
                            else
                            {
                                <a class="nav-link animate__animated animate__fadeIn p-0" href="/Home/SetLang?Lang=ar-SA&returnUrl=@Context.Request.Path" title="Switch to العربية">
                                    <span class="badge bg-glass text-white rounded-pill px-3 py-2 border border-white-10 d-flex align-items-center hover-glow" style="background: rgba(255,255,255,0.05);">
                                        <span class="fi fi-eg me-2 rounded-1"></span> العربية
                                    </span>
                                </a>
                            }
                        }
                    </li>
                </ul>
                                
                <div class="navbar-nav align-items-center">
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </div>
</header>
<!-- End Header -->