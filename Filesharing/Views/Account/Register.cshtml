@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

@*<h1>@ViewData["Title"]</h1>*@


<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper pb-5 pt-5">
    <div class="container text-center">
        <h1 class="hero-title pt-5">@Localizer["Create Account"]</h1>
        <p class="text-muted">Join our community and start sharing your files today.</p>
    </div>
</div>

<div class="container mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 animate__animated animate__fadeInUp">
            <div class="download-card p-5">
                <div class="mu-title text-start mb-5 text-center">
                    <h2 class="font-weight-bold mb-3">Sign <span class="text-gradient">Up</span></h2>
                    <p class="text-muted small">Quick and easy registration to get you started.</p>
                </div>

                <form id="register-form" class="mu-contact-form" asp-controller="Account" asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                    
                    <div class="mb-4">
                        <label class="text-muted small mb-2 ml-2">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                            <input type="email" asp-for="Email" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 1.25rem 1.25rem 3.5rem;" placeholder="name@example.com" required>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 ml-2"></span>
                    </div>

                    <div class="mb-4">
                        <label class="text-muted small mb-2 ml-2">Password</label>
                        <div class="position-relative">
                            <i class="bi bi-key position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                            <input type="password" id="passwordInput" asp-for="Password" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 4rem 1.25rem 3.5rem;" placeholder="Select a strong password" required>
                             <button type="button" onclick="togglePassword('passwordInput', 'eyeIcon')" class="btn position-absolute text-muted p-0" style="right: 1.5rem; top: 50%; transform: translateY(-50%); border: none; background: none;">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 ml-2"></span>
                    </div>

                    <div class="mb-5">
                        <label class="text-muted small mb-2 ml-2">Confirm Password</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-check position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                            <input type="password" id="confirmPasswordInput" asp-for="ConfirmPassword" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 4rem 1.25rem 3.5rem;" placeholder="Repeat your password" required>
                             <button type="button" onclick="togglePassword('confirmPasswordInput', 'confirmEyeIcon')" class="btn position-absolute text-muted p-0" style="right: 1.5rem; top: 50%; transform: translateY(-50%); border: none; background: none;">
                                <i class="bi bi-eye" id="confirmEyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 ml-2"></span>
                    </div>

                    <div class="mb-4">
                        <button type="submit" class="btn btn-primary-modern btn-modern w-100 justify-content-center rounded-pill py-3">
                            <span>Register</span> <i class="bi bi-person-plus ml-2"></i>
                        </button>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-0">Already have an account? <a asp-action="Login" class="text-primary font-weight-bold">Log In Here</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
