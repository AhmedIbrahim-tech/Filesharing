@model LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<!-- Page Header -->
<div id="mu-page-header" class="hero-wrapper pb-5 pt-5">
    <div class="container text-center">
        <h1 class="hero-title pt-5">@Localizer["Log In"]</h1>
        <p class="text-muted">Welcome back! Please enter your credentials to continue.</p>
    </div>
</div>

<div class="container mt-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 animate__animated animate__fadeInUp">
            <div class="download-card p-5">
                <div class="mu-title text-start mb-5 text-center">
                    <h2 class="font-weight-bold mb-3">Sign <span class="text-gradient">In</span></h2>
                    <p class="text-muted small">Access your shared files and manage your account.</p>
                </div>

                <form id="login-form" class="mu-contact-form" asp-controller="Account" asp-route-returnurl="@ViewData["ReturnUrl"]" asp-action="login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                    
                    <div class="mb-4">
                        <label class="text-muted small mb-2 ml-2">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                            <input type="email" asp-for="Email" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 1.25rem 1.25rem 3.5rem;" placeholder="name@example.com" required>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 ml-2"></span>
                    </div>

                    <div class="mb-5">
                        <label class="text-muted small mb-2 ml-2">Password</label>
                        <div class="position-relative">
                            <i class="bi bi-key position-absolute text-primary" style="left: 1.5rem; top: 50%; transform: translateY(-50%);"></i>
                            <input type="password" id="passwordInput" asp-for="Password" class="form-control rounded-pill bg-dark border-0 pl-5 text-white" style="background: rgba(2, 6, 23, 0.5) !important; padding: 1.25rem 4rem 1.25rem 3.5rem;" placeholder="Your Security Key" required>
                             <button type="button" onclick="togglePassword()" class="btn position-absolute text-muted p-0" style="right: 1.5rem; top: 50%; transform: translateY(-50%); border: none; background: none;">
                                <i class="bi bi-eye" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 ml-2"></span>
                    </div>

                    <div class="mb-4">
                        <button type="submit" class="btn btn-primary-modern btn-modern w-100 justify-content-center rounded-pill py-3">
                            <span>Log In</span> <i class="bi bi-box-arrow-in-right ml-2"></i>
                        </button>
                    </div>

                    <div class="text-center mb-4">
                        <span class="text-muted small">Or continue with</span>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        <a class="btn btn-outline-modern btn-modern w-100 justify-content-center rounded-pill" asp-action="ExternalLogin" asp-route-Provider="Facebook" asp-controller="Account">
                            <i class="bi bi-facebook text-primary mr-2"></i> Sign in with Facebook
                        </a>

                        <a class="btn btn-outline-modern btn-modern w-100 justify-content-center rounded-pill" asp-action="ExternalLogin" asp-route-Provider="Google" asp-controller="Account">
                            <i class="bi bi-google text-danger mr-2"></i> Sign in with Google
                        </a>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="text-muted small mb-0">Don't have an account? <a asp-action="Register" class="text-primary font-weight-bold">Register Now</a></p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}